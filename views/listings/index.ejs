<% layout("/layouts/boilerplate") %>
<% success %>

<div class="container my-4">

  <!-- HORIZONTAL SCROLL SECTION -->
  <h4 class="mb-3">Featured Listings</h4>
  <div class="horizontal-scroll">
    <% for(let listing of allListings) { %>
      <div class="card listing-card">
        <a href="/listings/<%=listing._id%>">
          <img src="<%=listing.image.url%>" class="card-img-top" alt="">
        </a>
        <div class="card-body">
          <p class="card-title"><b><%=listing.title%></b></p>
          <p class="price-text">&#8377; <%=listing.price%> for 2 nights</p>
        </div>
      </div>
    <% } %>
  </div>

  <!-- VERTICAL GRID SECTION -->
  <h4 class="mt-5 mb-3">All Listings</h4>
  <div class="row g-4 vertical-grid">
    <% for(let listing of allListings) { %>
      <div class="col-lg-3 col-md-4 col-sm-6 col-12">
        <div class="card listing-card h-100">
          <a href="/listings/<%=listing._id%>">
            <img src="<%=listing.image.url%>" class="card-img-top" alt="">
          </a>
          <div class="card-body">
            <p class="card-title"><b><%=listing.title%></b></p>
            <p class="price-text">&#8377; <%=listing.price%> for 2 nights</p>
          </div>
        </div>
      </div>
    <% } %>
  </div>

</div>
