<% layout("/layouts/boilerplate")%>
  <!-- <body> -->
  <div class="container my-5">

    <!-- TITLE -->
    <div class="text-center mb-4">
      <h2 class="fw-bold">
        <%= listing.title %>
      </h2>
      <p class="text-muted">
        <%= listing.location %>, <%= listing.country %> ·
            Hosted by <%= listing.owner.username %>
      </p>
    </div>

    <!-- IMAGE -->
    <div class="row justify-content-center mb-5">
      <div class="col-lg-10">

          <img src="<%= listing.image.url %>" alt="<%= listing.title %>"
            class="img-fluid rounded-4 shadow-sm listing-img">

      </div>
    
    </div>

    <!-- MAIN CONTENT -->
    <div class="row justify-content-center g-4">

      <!-- LEFT : DETAILS -->
      <div class="col-lg-7 col-md-12">
        <div class="card border-0 shadow-sm rounded-4 p-4 h-100">
          <h5 class="fw-semibold mb-3">About this place</h5>
          <p class="text-muted">
            <%= listing.description %>
          </p>

          <hr>

          <p><strong>📍 Location:</strong>
            <%= listing.location %>
          </p>
          <p><strong>🌍 Country:</strong>
            <%= listing.country %>
          </p>

          <% if (currUser && listing.owner._id.equals(currUser._id)) { %>
            <div class="d-flex gap-3 mt-4">
              <a href="/listings/edit/<%= listing._id %>" class="btn btn-outline-dark">
                Edit
              </a>
              <form method="POST" action="/listings/<%= listing._id %>?_method=DELETE">
                <button class="btn btn-danger">Delete</button>
              </form>
            </div>
            <% } %>
        </div>
      </div>

      <!-- RIGHT : PRICE BOX -->
      <div class="col-lg-4 col-md-8">
        <div class="card shadow-lg border-0 rounded-4 p-4 sticky-top price-card">
          <h4 class="fw-bold mb-3">
            ₹<%= listing.price %> <span class="fs-6 text-muted">/ 2 nights</span>
          </h4>

          <div class="border rounded-3 p-3 mb-3">
            <div class="d-flex justify-content-between">
              <span>Check-in</span>
              <span>Check-out</span>
            </div>
            <hr>
            <div class="text-center fw-semibold">Guests ⌄</div>
          </div>

          <button class="btn btn-danger w-100 rounded-pill py-3 fw-semibold">
            Reserve
          </button>

          <p class="text-center text-muted mt-2">
            You won’t be charged yet
          </p>
        </div>
      </div>

    </div>

    <hr>
    <div class="row justify-content-center mt-5">
      <div class="col-lg-8 col-md-10 col-12 mx-auto">

        <% if(currUser){ %>
          <form action="/listings/<%=listing.id%>/reviews" method="POST" novalidate
            class="needs-validation review-form">

            <fieldset class="starability-slot">
              <legend>Rate this place</legend>

              <input type="radio" id="no-rate" class="input-no-rate" name="review[rating]" value="0" checked>

              <input type="radio" id="first-rate1" name="review[rating]" value="1">
              <label for="first-rate1" title="Terrible">1 star</label>

              <input type="radio" id="first-rate2" name="review[rating]" value="2">
              <label for="first-rate2" title="Not good">2 stars</label>

              <input type="radio" id="first-rate3" name="review[rating]" value="3">
              <label for="first-rate3" title="Average">3 stars</label>

              <input type="radio" id="first-rate4" name="review[rating]" value="4">
              <label for="first-rate4" title="Very good">4 stars</label>

              <input type="radio" id="first-rate5" name="review[rating]" value="5">
              <label for="first-rate5" title="Amazing">5 stars</label>
            </fieldset>

            <label for="comment" class="form-label mt-3"> Comments</label>
            <textarea name="review[comment]" id="comment" rows="4" class="form-control" required></textarea>
            <div class="invalid-feedback">Please add comments!</div>

            <button class="btn btn-success mt-3">Add</button>

          </form>
          <% } %>

            <!-- Reviews -->
            <div class="row g-3 mt-4">

              <% for(review of listing.reviews){ %>
                <div class="col-lg-6 col-md-6 col-12">
                  <div class="card border-0 shadow-sm rounded-4 p-3 h-100 review-card">

                    <h6 class="fw-bold mb-1">
                      <%=review.author.username%>
                    </h6>
                    <img style="width: 55px; height: 55px;" src="<%= listing.image.url %>" alt="<%= listing.title %>"
                      class="img-fluid rounded-4 shadow-sm listing-img">
                    <p class="starability-result mb-2" data-rating="<%= review.rating %>"></p>

                    <p class="text-muted mb-2"><svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-chat-square-text" viewBox="0 0 16 16">
  <path d="M14 1a1 1 0 0 1 1 1v8a1 1 0 0 1-1 1h-2.5a2 2 0 0 0-1.6.8L8 14.333 6.1 11.8a2 2 0 0 0-1.6-.8H2a1 1 0 0 1-1-1V2a1 1 0 0 1 1-1zM2 0a2 2 0 0 0-2 2v8a2 2 0 0 0 2 2h2.5a1 1 0 0 1 .8.4l1.9 2.533a1 1 0 0 0 1.6 0l1.9-2.533a1 1 0 0 1 .8-.4H14a2 2 0 0 0 2-2V2a2 2 0 0 0-2-2z"/>
  <path d="M3 3.5a.5.5 0 0 1 .5-.5h9a.5.5 0 0 1 0 1h-9a.5.5 0 0 1-.5-.5M3 6a.5.5 0 0 1 .5-.5h9a.5.5 0 0 1 0 1h-9A.5.5 0 0 1 3 6m0 2.5a.5.5 0 0 1 .5-.5h5a.5.5 0 0 1 0 1h-5a.5.5 0 0 1-.5-.5"/>
</svg>
                      <%=review.comment%>
                    </p>
                    <%if(currUser && listing.owner._id.equals(currUser._id)){%>
                      <form method="POST" action="/listings/<%=listing._id%>/reviews/<%=review._id%>?_method=DELETE">
                        <button class=" btn btn-danger"><svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-trash3" viewBox="0 0 16 16">
  <path d="M6.5 1h3a.5.5 0 0 1 .5.5v1H6v-1a.5.5 0 0 1 .5-.5M11 2.5v-1A1.5 1.5 0 0 0 9.5 0h-3A1.5 1.5 0 0 0 5 1.5v1H1.5a.5.5 0 0 0 0 1h.538l.853 10.66A2 2 0 0 0 4.885 16h6.23a2 2 0 0 0 1.994-1.84l.853-10.66h.538a.5.5 0 0 0 0-1zm1.958 1-.846 10.58a1 1 0 0 1-.997.92h-6.23a1 1 0 0 1-.997-.92L3.042 3.5zm-7.487 1a.5.5 0 0 1 .528.47l.5 8.5a.5.5 0 0 1-.998.06L5 5.03a.5.5 0 0 1 .47-.53Zm5.058 0a.5.5 0 0 1 .47.53l-.5 8.5a.5.5 0 1 1-.998-.06l.5-8.5a.5.5 0 0 1 .528-.47M8 4.5a.5.5 0 0 1 .5.5v8.5a.5.5 0 0 1-1 0V5a.5.5 0 0 1 .5-.5"/>
</svg></button>
                      </form>
                      <%}%>

                  </div>
                  <%}%>
                </div>

            </div>
      </div>

    </div>

    <!-- </body> -->
    <template id="drop-down">
      <div class="guest-row">
        <div class="label">
          <strong>Adults</strong>
          <p>Age 13+</p>
        </div>
        <div class="counter">
          <button class="minus">-</button>
          <span class="count">1</span>
          <button class="plus">+</button>
        </div>
      </div>
      <div class="guest-row">
        <div class="label">
          <strong>Adults</strong>
          <p>Age 13+</p>
        </div>
        <div class="counter">
          <button class="minus">-</button>
          <span class="count">1</span>
          <button class="plus">+</button>
        </div>
      </div>
      <div class="guest-row">
        <div class="label">
          <strong>Adults</strong>
          <p>Age 13+</p>
        </div>
        <div class="counter">
          <button class="minus">-</button>
          <span class="count">1</span>
          <button class="plus">+</button>
        </div>
      </div>
      <div class="guest-row">
        <div class="label">
          <strong>Adults</strong>
          <p>Age 13+</p>
        </div>
        <div class="counter">
          <button class="minus">-</button>
          <span class="count">1</span>
          <button class="plus">+</button>
        </div>
      </div>
    </template>