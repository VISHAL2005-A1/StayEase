<% layout("/layouts/boilerplate")%>
    <!-- <body> -->
    <div class="row offset-2 mix">
        <h2 class="mb-3 mt-3">
            <%=listing.title%>
        </h2>

        <div class="cardimg ">
            <img width="80%" height="380px" src="<%=listing.image.url%>" alt="">
        </div>


        <i>Owned by:
            <%=listing.owner.username%>
        </i>
        <br>
        <strong>
            <%=listing.description%>
        </strong>

        <strong>
            <%=listing.location%>
        </strong>
        <br>
        <strong>
            <%=listing.country%>
        </strong>

        <div class="price-box">
            <div>
                <div class="reserve">
                    <strong> &#8377; <%=listing.price %> </strong>
                    <p> for 2 night</p>
                    <br>
                </div>
            </div>
            <div>
                <div class="check">
                    <p class="item-1">CHECK-IN</p>
                    <p class="item-2">CHECK-OUT</p>
                    <p class="item-3">Guests<img id="arrow" src="/css/1.svg" alt=""></p>
                    <p id="dropcontent"></p>


                </div>

            </div>
            <button style="width: 300px; height: 70px; border-radius: 45px;" class="btn btn-danger">Reserve</button>

            <p>You won't be charged yet</p>
        </div><br>
        <%if(currUser&& listing.owner._id.equals(currUser._id)){%>
            <div class="row mt-4 ">
                <div class="mb-2 col-md-3">

                    <a style="width: 150px;" class="btn btn-dark " href="/listings/edit/<%=listing._id%>">
                        Edit
                    </a>
                </div>
                <div class="mb-2 col-md-3">

                    <form method="POST" action="/listings/<%=listing._id%>?_method=DELETE">
                        <button style="width: 150px;" class="btn btn-danger">Delete</button>
                    </form>
                </div>

            </div>
            <%}%>

                <hr>
                <div class="col-8 offset-3 mb-3">
                    <%if(currUser){%>
                        <form action="/listings/<%=listing.id%>/reviews" method="POST" novalidate
                            class="needs-validation">
                            <div class="mb-3 mt-3">
                                <!-- <label for="rating" class="form-label"><b>Rating</b></label>
                                <input type="range" min="1" max="5" id="rating" name="review[rating]"
                                    class="form-range" /> -->

                                <fieldset class="starability-slot">
                                    <legend>First rating:</legend>
                                    <input type="radio" id="no-rate" class="input-no-rate" name="review[rating]" value="0"
                                        checked aria-label="No rating." />
                                    <input type="radio" id="first-rate1" name="review[rating]" value="1" />
                                    <label for="first-rate1" title="Terrible">1 star</label>
                                    <input type="radio" id="first-rate2" name="review[rating]" value="2" />
                                    <label for="first-rate2" title="Not good">2 stars</label>
                                    <input type="radio" id="first-rate3" name="review[rating]" value="3" />
                                    <label for="first-rate3" title="Average">3 stars</label>
                                    <input type="radio" id="first-rate4" name="review[rating]" value="4" />
                                    <label for="first-rate4" title="Very good">4 stars</label>
                                    <input type="radio" id="first-rate5" name="review[rating]" value="5" />
                                    <label for="first-rate5" title="Amazing">5 stars</label>
                                </fieldset>


                                <label for="comment" class="form-label">Comments</label>
                                <div>
                                    <textarea name="review[comment]" id="comment" cols="50" rows="5" class="form-label"
                                        required></textarea>
                                    <class class="invalid-feedback">Please add comments!</class>

                                </div>
                                <button class="btn btn-dark">Submit</button>



                            </div>
                        </form>
                        <%}%>
                            <!-- <h4>All reviews</h4> 
             <ul>
               <% for(review of listing.reviews){%>
               <li><%=review.comment%>,<%=review.rating%></li>
               <%}%>
            </ul>  -->

                            <div class="row">

                                <% for(review of listing.reviews){%>
                                    <!-- <div class="col-sm-6 mb-3 mb-sm-0"> -->
                                    <div class="card col-6 mb-3">
                                        <div class="card-body">
                                            <h5 class="card-title">
                                                <%=review.author.username%>
                                            </h5>
                                            <p class="starability-result card-title" data-rating=<%= review.rating %>>
                                               
                                            </p>
                                            <p class="card-title">
                                                <%=review.comment%>
                                            </p>
                                            <!-- <p class="card-text"><b>
                                                    <%=review.rating%> stars
                                                </b>
                                            </p> -->
                                            <form method="POST"
                                                action="/listings/<%=listing._id%>/reviews/<%=review._id%>?_method=DELETE">
                                                <button class="badge text-bg-secondary">Delete</button>
                                            </form>
                                        </div>
                                    </div>
                                    <!-- </div> -->
                                    <%}%>

                            </div>
                </div>
    </div>

    <!-- </body> -->
    <template id="drop-down">
        <div class="guest-row">
            <div class="label">
                <strong>Adults</strong>
                <p>Age 13+</p>
            </div>
            <div class="counter">
                <button class="minus">-</button>
                <span class="count">1</span>
                <button class="plus">+</button>
            </div>
        </div>
        <div class="guest-row">
            <div class="label">
                <strong>Adults</strong>
                <p>Age 13+</p>
            </div>
            <div class="counter">
                <button class="minus">-</button>
                <span class="count">1</span>
                <button class="plus">+</button>
            </div>
        </div>
        <div class="guest-row">
            <div class="label">
                <strong>Adults</strong>
                <p>Age 13+</p>
            </div>
            <div class="counter">
                <button class="minus">-</button>
                <span class="count">1</span>
                <button class="plus">+</button>
            </div>
        </div>
        <div class="guest-row">
            <div class="label">
                <strong>Adults</strong>
                <p>Age 13+</p>
            </div>
            <div class="counter">
                <button class="minus">-</button>
                <span class="count">1</span>
                <button class="plus">+</button>
            </div>
        </div>
    </template>