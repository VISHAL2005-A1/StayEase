<% layout("/layouts/boilerplate")%>
    <!-- <body> -->
   <div class="container my-5">

  <!-- TITLE -->
  <div class="text-center mb-4">
    <h2 class="fw-bold"><%= listing.title %></h2>
    <p class="text-muted">
      <%= listing.location %>, <%= listing.country %> ·
      Hosted by <%= listing.owner.username %>
    </p>
  </div>

  <!-- IMAGE -->
  <div class="row justify-content-center mb-5">
    <div class="col-lg-10">
      <img src="<%= listing.image.url %>" 
           alt="<%= listing.title %>" 
           class="img-fluid rounded-4 shadow-sm listing-img">
    </div>
  </div>

  <!-- MAIN CONTENT -->
  <div class="row justify-content-center g-4">

    <!-- LEFT : DETAILS -->
    <div class="col-lg-7 col-md-12">
      <div class="card border-0 shadow-sm rounded-4 p-4 h-100">
        <h5 class="fw-semibold mb-3">About this place</h5>
        <p class="text-muted"><%= listing.description %></p>

        <hr>

        <p><strong>📍 Location:</strong> <%= listing.location %></p>
        <p><strong>🌍 Country:</strong> <%= listing.country %></p>

        <% if (currUser && listing.owner._id.equals(currUser._id)) { %>
        <div class="d-flex gap-3 mt-4">
          <a href="/listings/edit/<%= listing._id %>" class="btn btn-outline-dark">
            Edit
          </a>
          <form method="POST" action="/listings/<%= listing._id %>?_method=DELETE">
            <button class="btn btn-danger">Delete</button>
          </form>
        </div>
        <% } %>
      </div>
    </div>

    <!-- RIGHT : PRICE BOX -->
    <div class="col-lg-4 col-md-8">
      <div class="card shadow-lg border-0 rounded-4 p-4 sticky-top price-card">
        <h4 class="fw-bold mb-3">
          ₹<%= listing.price %> <span class="fs-6 text-muted">/ 2 nights</span>
        </h4>

        <div class="border rounded-3 p-3 mb-3">
          <div class="d-flex justify-content-between">
            <span>Check-in</span>
            <span>Check-out</span>
          </div>
          <hr>
          <div class="text-center fw-semibold">Guests ⌄</div>
        </div>

        <button class="btn btn-danger w-100 rounded-pill py-3 fw-semibold">
          Reserve
        </button>

        <p class="text-center text-muted mt-2">
          You won’t be charged yet
        </p>
      </div>
    </div>

  </div>

                <hr>
            <div class="row justify-content-center mt-5">
           <div class="col-lg-8 col-md-10 col-12 mx-auto">

  <% if(currUser){ %>
  <form action="/listings/<%=listing.id%>/reviews" method="POST" novalidate class="needs-validation review-form">

    <fieldset class="starability-slot">
      <legend>Rate this place</legend>

      <input type="radio" id="no-rate" class="input-no-rate" name="review[rating]" value="0" checked>
      
      <input type="radio" id="first-rate1" name="review[rating]" value="1">
      <label for="first-rate1" title="Terrible">1 star</label>

      <input type="radio" id="first-rate2" name="review[rating]" value="2">
      <label for="first-rate2" title="Not good">2 stars</label>

      <input type="radio" id="first-rate3" name="review[rating]" value="3">
      <label for="first-rate3" title="Average">3 stars</label>

      <input type="radio" id="first-rate4" name="review[rating]" value="4">
      <label for="first-rate4" title="Very good">4 stars</label>

      <input type="radio" id="first-rate5" name="review[rating]" value="5">
      <label for="first-rate5" title="Amazing">5 stars</label>
    </fieldset>

    <label for="comment" class="form-label mt-3">Comments</label>
    <textarea name="review[comment]" id="comment" rows="4" class="form-control" required></textarea>
    <div class="invalid-feedback">Please add comments!</div>

    <button class="btn btn-dark mt-3">Submit</button>

  </form>
  <% } %>

  <!-- Reviews -->
  <div class="row g-3 mt-4">

    <% for(review of listing.reviews){ %>
    <div class="col-lg-6 col-md-6 col-12">
      <div class="card border-0 shadow-sm rounded-4 p-3 h-100 review-card">

        <h6 class="fw-bold mb-1"><%=review.author.username%></h6>

        <p class="starability-result mb-2" data-rating="<%= review.rating %>"></p>

        <p class="text-muted mb-2"><%=review.comment%></p>
         <%if(currUser && listing.owner._id.equals(currUser._id)){%>}
        <form method="POST"
          action="/listings/<%=listing._id%>/reviews/<%=review._id%>?_method=DELETE">
          <button class="badge text-bg-secondary">Delete</button>
        </form><%}%>

      </div>
    </div>
    <% } %>

  </div>
</div>

    </div>

